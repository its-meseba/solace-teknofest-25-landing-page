<svg width="240" height="240" viewBox="0 0 240 240" xmlns="http://www.w3.org/2000/svg">
  <rect width="240" height="240" fill="#f5f5f5"/>
  <g transform="translate(20, 30)">
    <!-- Box body -->
    <rect x="30" y="60" width="140" height="100" rx="5" fill="#FFF" stroke="#E0E0E0" stroke-width="1"/>
    
    <!-- Wooden top -->
    <rect x="30" y="40" width="140" height="30" rx="5" fill="#8B4513"/>
    <rect x="30" y="40" width="140" height="30" rx="5" fill="url(#wood)"/>
    
    <!-- Logo on top -->
    <circle cx="100" cy="55" r="8" fill="#FFF" opacity="0.7"/>
    
    <!-- Bottom slight shadow -->
    <rect x="30" y="160" width="140" height="5" rx="2" fill="#E0E0E0"/>
  </g>
  
  <!-- Wood grain pattern -->
  <defs>
    <pattern id="wood" patternUnits="userSpaceOnUse" width="100" height="30" patternTransform="rotate(0)">
      <rect width="100" height="30" fill="#8B4513"/>
      <line x1="0" y1="5" x2="100" y2="5" stroke="#6B3100" stroke-width="0.5" opacity="0.3"/>
      <line x1="0" y1="10" x2="100" y2="10" stroke="#9A6033" stroke-width="0.5" opacity="0.3"/>
      <line x1="0" y1="15" x2="100" y2="15" stroke="#6B3100" stroke-width="0.5" opacity="0.3"/>
      <line x1="0" y1="20" x2="100" y2="20" stroke="#9A6033" stroke-width="0.5" opacity="0.3"/>
      <line x1="0" y1="25" x2="100" y2="25" stroke="#6B3100" stroke-width="0.5" opacity="0.3"/>
    </pattern>
  </defs>
</svg> 